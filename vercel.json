{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/horarios-disponibles", "dest": "/api/horarios-disponibles.js" },
    { "src": "/api/reservas/([^/]+)", "dest": "/api/reservas/[id].js?id=$1" },
    { "src": "/api/reservas", "dest": "/api/reservas/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
